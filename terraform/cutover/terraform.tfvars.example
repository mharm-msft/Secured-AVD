# =====================================================================================
# terraform.tfvars.example (CUTOVER) — copy to terraform.tfvars and edit.
#
#   cp terraform.tfvars.example terraform.tfvars
#   export TF_VAR_adminPassword='ChangeMeBeforeDeploy!1'
#   terraform init
#   terraform plan
#
# IMPORTANT: To deploy side-by-side in the SAME subscription as the old AVD stack,
# differentiate `namingPrefix` or `environment` here so the new resources don't
# collide with the old ones.
# =====================================================================================

# naming — DIFFERENTIATE from the old stack
namingPrefix = "savd2"
environment  = "prod"

# location — typically MATCH the old stack
location            = "eastus2"
avdMetadataLocation = "eastus"

tags = {
  workload          = "avd"
  environment       = "prod"
  managedBy         = "Secured-AVD-IaC"
  deploymentPattern = "cutover"
  costCenter        = "IT-Eng-001"
}

# network — non-overlapping CIDR with old stack
vnetAddressSpace = "10.51.0.0/22"
hostsSubnetCidr  = "10.51.0.0/24"
peSubnetCidr     = "10.51.1.0/27"
mgmtSubnetCidr   = ""
hubVnetId        = ""
dnsServers       = []

# host pool
hostPoolType          = "Pooled"
loadBalancerType      = "BreadthFirst"
maxSessionLimit       = 8
preferredAppGroupType = "Desktop"
validationEnvironment = false
startVMOnConnect      = true

# session hosts
vmSize            = "Standard_D4s_v5"
vmCount           = 2
availabilityZones = [1, 2, 3]
osDiskType        = "Premium_LRS"
osDiskSizeGb      = 128
imageReference = {
  kind  = "marketplace"
  alias = "win11-24h2-avd-m365"
}
adminUsername          = "savdadmin"
enableIntuneEnrollment = true

# identity — usually SAME group as old stack so users access both during cutover
desktopUserGroupObjectId = "00000000-0000-0000-0000-000000000000"
adminUserGroupObjectId   = ""

# shortpath
rdpShortpathMode = "Both"

# fslogix — profiles do NOT auto-migrate; see docs/rip-and-replace-runbook.md
enableFSLogix         = false
fslogixStorageSkuName = "Premium_LRS"
fslogixShareQuotaGb   = 1024

# monitoring — recommend BYO old-stack LAW so observability stays in one place
logAnalyticsWorkspaceId = ""
logRetentionDays        = 30

# ---- Cutover-only -----------------------------------------------------------
# Resource IDs of the OLD AVD stack you are replacing.
existingHostPoolResourceId  = "/subscriptions/00000000-0000-0000-0000-000000000000/resourceGroups/rg-savd-prod-eus2/providers/Microsoft.DesktopVirtualization/hostPools/savd-prod-hp-eus2"
existingWorkspaceResourceId = "/subscriptions/00000000-0000-0000-0000-000000000000/resourceGroups/rg-savd-prod-eus2/providers/Microsoft.DesktopVirtualization/workspaces/savd-prod-ws-eus2"
drainOldHostPool            = true
